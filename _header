/Build/*.gz
  Cache-Control: no-transform
  Content-Encoding: gzip

/Build/*.framework.js.gz
  Cache-Control: no-transform
  Content-Encoding: gzip
  Content-Type: application/javascript

/Build/*.wasm.gz
  Cache-Control: no-transform
  Content-Encoding: gzip
  Content-Type: application/wasm

/Build/*.data.gz
  Cache-Control: no-transform
  Content-Encoding: gzip
  Content-Type: application/octet-stream

/Build/*.loader.js
  Content-Type: application/javascript

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' blob:; connect-src 'self' https://shopkofi.sleetsheet-st.workers.dev; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline';
